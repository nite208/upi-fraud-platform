# =============================================================================
# UPI Fraud Detection Platform — Docker Compose Environment Variables
# Copy this file to .env and adjust values before running:
#   cp .env.example .env
#   docker compose up -d
# =============================================================================

# --- TimescaleDB (PostgreSQL) ---
POSTGRES_DB=frauddb
POSTGRES_USER=frauduser
POSTGRES_PASSWORD=fraudpass
TIMESCALEDB_PORT=5432

# --- Neo4j ---
NEO4J_AUTH=neo4j/fraudpass123
NEO4J_USER=neo4j
NEO4J_PASSWORD=fraudpass123
NEO4J_HEAP_SIZE=2G
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# --- Redis ---
REDIS_PORT=6379

# --- Zookeeper ---
ZOOKEEPER_PORT=2181

# --- Kafka ---
KAFKA_PORT=9092
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1

# --- Kafka UI ---
KAFKA_UI_PORT=8080

# --- Apache Flink ---
FLINK_JOBMANAGER_PORT=8081
FLINK_TASK_SLOTS=2

# --- MLflow ---
MLFLOW_PORT=5000

# --- ChromaDB ---
CHROMADB_PORT=8001

# --- Ollama ---
OLLAMA_PORT=11434

# --- Prometheus ---
PROMETHEUS_PORT=9090

# --- Grafana ---
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# --- Fraud API ---
FRAUD_API_PORT=8000

# --- Celery Worker ---
CELERY_APP=app.celery
CELERY_LOG_LEVEL=info
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
